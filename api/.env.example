# Aria API – environment variables
# Copy this file to .env and fill in values before running

# Server
HOST=0.0.0.0
PORT=8000

# CORS – Next.js frontend origin
FRONTEND_URL=http://localhost:3000

# Phase 2 – AI integration (not used yet)
# ANTHROPIC_API_KEY=sk-ant-...

# Phase 2 – QuickBooks OAuth
# QB_CLIENT_ID=
# QB_CLIENT_SECRET=
# QB_REDIRECT_URI=http://localhost:8000/integrations/quickbooks/callback

# Phase 2 – NetSuite
# NETSUITE_ACCOUNT_ID=
# NETSUITE_CONSUMER_KEY=
# NETSUITE_CONSUMER_SECRET=

# Phase 2 – Rippling
# RIPPLING_API_KEY=

# Phase 2 – Gusto
# GUSTO_CLIENT_ID=
# GUSTO_CLIENT_SECRET=
